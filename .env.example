# ═══════════════════════════════════════
# MEETZY — Variables de entorno
# Copiá este archivo a .env y completá los valores
# ═══════════════════════════════════════

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/meetzy

# Upstash Redis (https://upstash.com → crear database)
REDIS_URL=https://xxx.upstash.io
REDIS_TOKEN=your_upstash_token

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# ElevenLabs (Plan Elite — https://elevenlabs.io)
ELEVENLABS_API_KEY=...

# Simli.ai (Plan Elite — https://simli.ai)
SIMLI_API_KEY=...

# Clerk (https://clerk.com → crear app → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
