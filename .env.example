# ═══════════════════════════════════════
# MEETZY — Variables de entorno
# Copiá este archivo a .env y completá los valores
# ═══════════════════════════════════════

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/meetzy

# Upstash Redis (https://upstash.com → crear database)
REDIS_URL=https://xxx.upstash.io
REDIS_TOKEN=your_upstash_token

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# ElevenLabs (Plan Elite — https://elevenlabs.io)
ELEVENLABS_API_KEY=...

# Simli.ai (Plan Elite — https://simli.ai)
SIMLI_API_KEY=...

# NextAuth — generá el secret con: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Google OAuth (https://console.cloud.google.com)
# Crear proyecto → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...

# Resend (email magic link — https://resend.com)
RESEND_API_KEY=re_...

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
