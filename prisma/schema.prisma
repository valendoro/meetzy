generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  plan             String        @default("starter")
  stripeCustomerId String?
  isReseller       Boolean       @default(false)
  resellerBrand    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  sites            Site[]
  accounts         Account[]
  sessions         Session[]
  subscription     Subscription?
}

model Site {
  id                   String           @id @default(cuid())
  siteId               String           @unique @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id])
  name                 String
  url                  String
  plan                 String           @default("starter")
  isActive             Boolean          @default(true)
  agentName            String           @default("Meetzy")
  agentRole            String           @default("Asistente virtual")
  agentPersonality     String           @default("amigable y profesional")
  welcomeMessage       String           @default("¡Hola! ¿En qué te puedo ayudar?")
  systemPrompt         String           @db.Text
  language             String           @default("es")
  avatarType           String?
  avatarSubtype        String?
  brandColor           String           @default("#6366f1")
  brandColor2          String           @default("#8b5cf6")
  logoUrl              String?
  avatarImageUrl       String?          // Imagen 3D generada (fal.ai) u optimizada
  avatarGenerations    Int              @default(0)
  onboardingCompleted  Boolean          @default(false)
  onboardingStep       Int              @default(1)
  avatarConfig         Json?
  voiceEnabled         Boolean          @default(false)
  voiceId              String?
  simliAvatarId        String?
  calBookingUrl        String?
  webhookUrl           String?
  embedMode            String           @default("widget")
  primaryQuestion      String?
  agentType            String           @default("guia")
  proactiveEnabled     Boolean          @default(true)
  proactiveFrequency   String           @default("normal")
  exitIntentEnabled    Boolean          @default(true)
  widgetPosition       String           @default("bottom-right")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  conversations        Conversation[]
  visitorProfiles      VisitorProfile[]
}

model Conversation {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorId String

  visitorEmail   String?
  visitorName    String?
  visitorCompany String?

  country String?
  city    String?

  source      String?
  referrer    String?
  searchQuery String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  pagesVisited    String[] @default([])
  sessionDuration Int      @default(0)
  activeTime      Int      @default(0)
  scrollDepth     Int      @default(0)
  sectionsViewed  Json?

  intentScore      Int    @default(0)
  intentLabel      String @default("exploring")
  demoBooked       Boolean @default(false)
  intentSignalsLog Json?

  device  String?
  browser String?

  metadata       Json?
  visitorPersona String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model VisitorProfile {
  id        String @id @default(cuid())
  visitorId String
  siteId    String
  site      Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  email   String?
  name    String?
  company String?

  totalVisits   Int @default(1)
  totalMessages Int @default(0)
  totalTime     Int @default(0)

  maxIntentScore Int    @default(0)
  maxIntentLabel String @default("exploring")
  demoBooked     Boolean @default(false)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  country   String?
  topSource String?

  contactedAt DateTime?

  @@unique([visitorId, siteId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  uiComponents   Json?
  intentScore    Float?
  intentSignals  Json?
  createdAt      DateTime     @default(now())
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])
  stripeSubscriptionId String   @unique
  plan                 String
  status               String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
